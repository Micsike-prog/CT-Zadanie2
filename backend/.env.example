# PostgreSQL
DATABASE_URL=postgresql://pothole:pothole@localhost:5432/pothole_db
RUN_MIGRATIONS_ON_STARTUP=true

# JWT
# Use a long random value in real deployment.
JWT_SECRET=replace-with-random-secret
JWT_EXPIRES_SECONDS=3600

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Uploads
# 25 MB
MAX_UPLOAD_BYTES=26214400

# AWS credentials used by boto3.
# In Azure App Service / Render, set these as secure environment variables.
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_REGION=eu-central-1

# Private S3 bucket for original uploaded images.
S3_BUCKET=your-private-pothole-images-bucket
S3_PRESIGN_SECONDS=3600

# Private AWS Lambda function invoked through boto3.
LAMBDA_FUNCTION_NAME=your-pothole-yolov8-lambda-name
