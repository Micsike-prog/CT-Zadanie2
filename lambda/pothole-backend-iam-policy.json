{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListPotholeImageBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::pothole-ai-images-ct-797795454892-eu-central-1-an"
    },
    {
      "Sid": "ReadWriteUploadedImages",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::pothole-ai-images-ct-797795454892-eu-central-1-an/uploads/originals/*"
    },
    {
      "Sid": "InvokePotholeLambda",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": "arn:aws:lambda:eu-central-1:797795454892:function:pothole-lambda"
    }
  ]
}
